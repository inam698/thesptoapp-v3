rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: check if the requesting user has admin role in Firestore
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Admin uploads (featured images, etc.) — public read, admin-only write
    match /admin-uploads/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User avatars — owner can upload their own, anyone can read
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Block everything else by default
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
