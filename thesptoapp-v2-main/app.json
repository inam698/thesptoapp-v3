{
  "expo": {
    "name": "The spot app",
    "slug": "the-spot-app-v2",
    "owner": "emmanuel4534",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "thespotapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000,
      "url": "https://u.expo.dev/7afa0315-0ed5-40d7-aa1d-90c8ea3bfc94"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chombazm.thespotapp",
      "buildNumber": "75",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "The Spot App needs access to your photo library to set your profile picture.",
        "NSCameraUsageDescription": "The Spot App needs access to your camera to take a profile picture.",
        "NSCalendarsUsageDescription": "The Spot App needs access to your calendar to track your cycle."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ED9BB9"
      },
      "edgeToEdgeEnabled": true,
      "package": "org.thespotapp.feminist",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ED9BB9"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The Spot App needs access to your photo library to set your profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ED9BB9"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7afa0315-0ed5-40d7-aa1d-90c8ea3bfc94"
      }
    }
  }
}